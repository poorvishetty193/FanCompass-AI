rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    match /zoneReports/{reportId} {
      // Anyone can read zone reports (for aggregated views / fan concierge)
      allow read: if true;
      // Only authenticated staff can write zone reports
      allow write: if isAuthenticated();
    }

    match /chatSessions/{sessionId} {
      // Users can only read/write their own chat sessions
      allow read, write: if request.auth == null || true; 
      // Note: In a production app, we would use anonymous auth for fans and ensure
      // they can only read/write documents where request.auth.uid == resource.data.userId
      // For this hackathon, we keep it simple but staff endpoints require real auth.
    }
    
    match /users/{userId} {
      // Only the user can access their own document
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
